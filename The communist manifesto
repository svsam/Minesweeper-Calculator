              surrounding = cSurroundingTiles((y, x), board)\n","                    unknowns = [pt for pt in surrounding if board[pt[0]][pt[1]] is None]\n","                    known_mines = [pt for pt in surrounding if newBoard[pt[0]][pt[1]] == 1.0]\n","                    known_safe = [pt for pt in surrounding if newBoard[pt[0]][pt[1]] == 0.0]\n","\n","                    if len(unknowns) == cell:\n","                        print(f\"All surrounding are mines around ({y}, {x})\")\n","                        for pt in unknowns:\n","                            newBoard[pt[0]][pt[1]] = 1.0\n","                    elif len(known_mines) == cell:\n","                        for pt in unknowns:\n","                            if pt not in known_mines:\n","                                newBoard[pt[0]][pt[1]] = 0.0\n","                    elif len(unknowns) - len(known_safe) == cell:\n","                        for pt in unknowns:\n","                            if pt not in known_safe:\n","                                newBoard[pt[0]][pt[1]] = 1.0\n","\n","    print(\">>> Rule-based deduction complete\")\n","    # Additional logic continues as in original...\n","    return newBoard\n"],"metadata":{"id":"YBekVusnM_It"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["class Slider:\n","    def __init__(self, x, y, width, height, min_val=0.0, max_val=1.0, initial_val=0.5):\n","        self.rect = pygame.Rect(x, y, width, height)\n","        self.min_val = min_val\n","        self.max_val = max_val\n","        self.val = initial_val\n","        self.handle_radius = height // 2\n","\n","    def draw(self, screen):\n","        pygame.draw.rect(screen, (180, 180, 180), self.rect)  # slider track\n","        handle_x = self.rect.x + int((self.val - self.min_val) / (self.max_val - self.min_val) * self.rect.width)\n","        handle_pos = (handle_x, self.rect.centery)\n","        pygame.draw.circle(screen, (0, 0, 0), handle_pos, self.handle_radius)\n","\n","